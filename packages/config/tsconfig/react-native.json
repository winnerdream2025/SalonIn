{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "React Native / Expo",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "allowJs": true,
    "jsx": "react-native",
    "declaration": false,
    "declarationMap": false
  }
}
