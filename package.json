{
  "name": "salonin",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "dependencies": {
    "@prisma/client": "^5.0.0"
  },
  "devDependencies": {
    "bcryptjs": "^3.0.3",
    "prettier": "^3.3.2",
    "prisma": "^5.0.0",
    "turbo": "^2.1.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.4.0",
  "prisma": {
    "seed": "ts-node --project tsconfig.seed.json prisma/seed.ts"
  },
  "pnpm": {
    "patchedDependencies": {
      "expo-modules-core@1.12.26": "patches/expo-modules-core@1.12.26.patch",
      "expo-device@5.9.4": "patches/expo-device@5.9.4.patch"
    }
  }
}
